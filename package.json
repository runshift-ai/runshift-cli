    "cli",
    "relay",
    "governance"
  ],
  "author": "Devin Crane",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.6.2",
    "figlet": "^1.11.0",
    "ora": "8.2.0"
  },
  "devDependencies": {
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.15.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.2"
  },
  "engines": {
    "node": ">=18"
  }
}
