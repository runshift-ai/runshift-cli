{
  "name": "runshift",
  "version": "0.0.15",
  "description": "The control plane for agents, wherever they run.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "runshift": "dist/index.js"
  },
  "files": [
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "dist/**/*.map",
    "!dist/__tests__/**",
